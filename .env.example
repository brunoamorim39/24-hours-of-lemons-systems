# 24 Hours of Lemons - Deployment Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to git (it's in .gitignore)

# ============================================================================
# Pi Network Configuration
# ============================================================================

# Default Pi hostname or IP address
DEFAULT_PI_HOST=lemons-car1.local

# Default car ID
DEFAULT_CAR_ID=car1

# SSH username (default: pi)
PI_USER=pi

# ============================================================================
# GitHub / Git Configuration (for private repos)
# ============================================================================

# Option 1: Personal Access Token (for HTTPS clone)
# Create at: https://github.com/settings/tokens
# Needs: repo (full control of private repositories)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option 2: SSH key path (for SSH clone)
# Generate on Pi: ssh-keygen -t ed25519 -C "lemons-deploy"
# Add to GitHub: Settings → SSH and GPG keys
SSH_KEY_PATH=~/.ssh/id_ed25519

# Repository URL
REPO_URL=https://github.com/your-org/24-hours-of-lemons-systems.git

# ============================================================================
# WiFi Configuration (for first-boot on fresh Pi)
# ============================================================================

# WiFi network name (SSID)
WIFI_SSID=PitBoxNetwork

# WiFi password
WIFI_PASSWORD=your-wifi-password

# WiFi country code (US, GB, etc.)
WIFI_COUNTRY=US

# ============================================================================
# Trackside Network (optional - for quick Pi discovery)
# ============================================================================

# Network range to scan for Pis
NETWORK_RANGE=192.168.1.0/24

# ============================================================================
# Golden Image Configuration
# ============================================================================

# Directory to store golden images
GOLDEN_IMAGE_DIR=./golden-images

# Image compression (yes/no)
COMPRESS_IMAGES=yes
